# ============================================================
# Work3Spaces Frontend – Environment Variables
# ============================================================
# 1. Copy this file to .env or .env.local before running the app:
#      cp .env.example .env
# 2. Tweak the values only if you need to hit another environment.
# 3. Restart Vite after changing env variables.
# ============================================================

# Primary entrypoint for Adapter, Virto, Contracts, and default Kreivo RPC.
# Dev default: https://dev.abako.xyz
# Prod example: https://abako.xyz
VITE_API_BASE_URL=https://dev.abako.xyz

# Express backend / proxy URL (BFF). Keep it in sync with whatever backend
# you run locally. Safe to leave identical to VITE_API_BASE_URL when the
# frontend talks straight to the public APIs.
VITE_BACKEND_URL=https://dev.abako.xyz

# Kreivo RPC endpoint. Override only if Kreivo lives on a different domain.
# Leaving the dev default below is equivalent to relying on the
#   ${VITE_API_BASE_URL}/kreivo
# fallback logic.
VITE_KREIVO_RPC_URL=https://dev.abako.xyz/kreivo

# Calendar contract address. Differs between dev/staging/production.
# Dev default: Dd34LSU53MLwJpq4wfHmDFwAifJrcaPbd1qTCGZcR7iXQkd
VITE_CALENDAR_ADDRESS=Dd34LSU53MLwJpq4wfHmDFwAifJrcaPbd1qTCGZcR7iXQkd
